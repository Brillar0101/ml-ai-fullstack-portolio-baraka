# Copy to .env.local and fill in real values. Never commit the filled file
# (.env* is gitignored). In production, set these in the Vercel project:
# Settings -> Environment Variables, then redeploy.

# Supabase — powers blog comments and analytics.
# Without both of these the client is null and the UI shows
# "Comments are temporarily unavailable." Find them in the Supabase
# dashboard: Project Settings -> API (Project URL and the anon/public key).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# EmailJS — powers the contact form. Find these in the EmailJS dashboard.
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
